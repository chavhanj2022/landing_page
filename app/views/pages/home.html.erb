<div class="landing">
  <header class="landing__nav">
    <span class="landing__brand">Landing Page</span>
    <nav>
      <a href="#features">Features</a>
      <a href="#about">About</a>
      <a href="#contact" class="landing__nav-cta">Contact</a>
    </nav>
  </header>

  <section class="landing__hero">
    <h1>Build something people love</h1>
    <p>A clean, fast starting point for your next idea — powered by Ruby on Rails 8.</p>
    <div class="landing__actions">
      <a href="#features" class="btn btn--primary">Get Started</a>
      <a href="#about" class="btn btn--ghost">Learn More</a>
    </div>
  </section>

  <section id="features" class="landing__features">
    <div class="feature">
      <h3>Fast</h3>
      <p>Built on modern Rails for speed and reliability out of the box.</p>
    </div>
    <div class="feature">
      <h3>Simple</h3>
      <p>A minimal, focused layout that you can extend however you like.</p>
    </div>
    <div class="feature">
      <h3>Flexible</h3>
      <p>Bring your own data and features when you're ready to grow.</p>
    </div>
  </section>

  <section id="about" class="landing__about">
    <h2>About</h2>
    <p>This is a simple landing page scaffold. Customize the copy, colors, and sections to match your product.</p>
  </section>

  <footer id="contact" class="landing__footer">
    <p>&copy; <%= Date.current.year %> Landing Page. All rights reserved.</p>
  </footer>
</div>
